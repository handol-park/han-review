#!/usr/bin/env bash
# han-review-init — install the han-review caller stub into a target repo.
#
# Usage: han-review-init [TARGET_DIR]   (default: current directory)
# Idempotent: writes <repo>/.github/workflows/han-review.yml from the stub
# shipped alongside this script. Pin @ref by editing the installed file.
set -euo pipefail

target="${1:-.}"
if [ ! -d "$target/.git" ] && ! git -C "$target" rev-parse --git-dir >/dev/null 2>&1; then
  echo "error: '$target' is not a git repository" >&2
  exit 1
fi

# Resolve the stub relative to this script (works via symlink too).
src="$(cd "$(dirname "$(readlink "${BASH_SOURCE[0]}" || echo "${BASH_SOURCE[0]}")")/.." && pwd)/templates/caller.yml"
if [ ! -f "$src" ]; then
  # Fallback: script lives at <repo>/bin, stub at <repo>/templates
  src="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)/templates/caller.yml"
fi
[ -f "$src" ] || { echo "error: cannot find templates/caller.yml" >&2; exit 1; }

dest_dir="$target/.github/workflows"
dest="$dest_dir/han-review.yml"
mkdir -p "$dest_dir"
if [ -f "$dest" ] && cmp -s "$src" "$dest"; then
  echo "han-review-init: $dest already up to date"
  exit 0
fi
cp "$src" "$dest"
echo "han-review-init: wrote $dest"
echo "Next: ensure the repo has the backend secret(s), commit the stub to the"
echo "default branch, then comment '@claude /han-review' (or @codex/@gemini-cli) on a PR."
